# DrChrono — same values as gcal-drchrono-sync/.env
DRCHRONO_CLIENT_ID=
DRCHRONO_CLIENT_SECRET=
DRCHRONO_DOCTOR_ID=

# Google Sheets — spreadsheet ID from the URL of the linked Google Form responses sheet
# e.g. https://docs.google.com/spreadsheets/d/THIS_PART/edit
INTAKE_SPREADSHEET_ID=

# Sheet tab name (default: "Form Responses 1")
INTAKE_RESPONSES_SHEET=Form Responses 1
